  "description": "Windows desktop app that syncs Mollie payment customers into an EmailOctopus list",
  "license": "MIT",
  "author": "AuditeMarlow",
  "repository": {
    "type": "git",
    "url": "https://github.com/AuditeMarlow/mollie-octopus-sync.git"
  },
