{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mollie to EmailOctopus Sync",
  "version": "0.0.7",
  "identifier": "com.auditemarlow.mollieoctopussync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mollie → EmailOctopus Sync",
        "width": 720,
        "height": 560,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Sync Mollie payments into an EmailOctopus list",
    "longDescription": "A lightweight Windows app that pulls Mollie payments and upserts contacts into a selected EmailOctopus list. Designed for Peggy Pay merchants whose payments are processed through Mollie.",
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AuditeMarlow/mollie-octopus-sync/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFQzE1RjQ0NTU4QjU1Q0EKUldUS1ZZdFZSRi9Cdm9Md2dtR1NEQy9LWXRrMDZkRkdtc3U3NG0zcDJiUy9VYzlEU0UvUDdFYSsK"
    }
  }
}